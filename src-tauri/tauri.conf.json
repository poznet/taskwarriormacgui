{
	"productName": "TaskFloat",
	"version": "0.1.0",
	"identifier": "pl.glajc.taskfloat",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../build"
	},
	"app": {
		"withGlobalTauri": true,
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "TaskFloat",
				"width": 380,
				"height": 600,
				"minWidth": 300,
				"minHeight": 400,
				"resizable": true,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": true,
				"visible": true
			}
		],
		"security": {
			"csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "app"],
		"icon": [
			"icons/icon.icns",
			"icons/icon.png"
		],
		"macOS": {
			"minimumSystemVersion": "13.0"
		}
	}
}
